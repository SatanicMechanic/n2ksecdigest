# Primary LLM: xAI (Grok)
XAI_API_KEY=xai-xxx

# Fallback LLM: GitHub Models. Fine-grained PAT with `models:read` scope.
# Used only when the xAI call fails.
GH_MODELS_TOKEN=ghp_xxx

# Email delivery (Resend)
RESEND_API_KEY=re_xxx
DIGEST_TO_EMAIL=you@example.com,other@example.com
DIGEST_FROM_EMAIL=digest@your-verified-domain.com

# Optional: Slack Incoming Webhook URL. When set, the plain-text digest is
# also posted to that channel. Unset = Slack step is a no-op.
#SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# Optional: SKIP-debug transparency report recipient. When set, runs that
# produce no digest email a plain-text dump of rejected candidates here.
# Leave unset to disable.
#SKIP_REPORT_TO_EMAIL=you@example.com

# Strongly recommended — without it the web-search pass is a no-op.
# Free tier: 2,000 queries/month (well above what this runs in a month).
BRAVE_API_KEY=BSA_xxx

# Optional: URL of a hosted Brave goggle to bias search ranking toward curated
# security sources. Brave fetches this URL at query time, so it must be
# PUBLICLY reachable — a private fork's own raw URL will NOT work. Default to
# the public upstream copy below. To customize, host your edited goggle at any
# public URL (a public gist works) — and since it must be public, keep the
# rules generic: don't encode stack hints (e.g. boosting only your vendors).
# Unset = no goggle applied.
#BRAVE_GOGGLES=https://raw.githubusercontent.com/SatanicMechanic/n2ksecdigest/main/security-news.goggle
